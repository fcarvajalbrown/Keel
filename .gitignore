# Build artifacts and large audio — keep code + docs, drop the audio.
out/*.wav
out/*.flac
out/REPORT.md
references/*.wav
references/*.flac
__pycache__/
*.pyc
_revalidate.py

# Virtual environments — machine/platform-specific, rebuilt via setup.ps1. Never commit.
.venv/
venv/
env/

# Local scratch (offline-vendor probes, throwaway test venvs).
_vendor_probe/
_vtest/

# User-created GUI presets (local data, not part of the engine).
userpresets.json

# PyInstaller packaging output (the .exe/.app are built, not committed).
build/
dist/
